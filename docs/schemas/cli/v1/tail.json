{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cannaradar.local/schemas/cli/v1/tail.json",
  "title": "CannaRadar tail output",
  "type": "object",
  "required": ["schema_version", "command", "ok", "data"],
  "properties": {
    "schema_version": { "const": "cli.v1" },
    "command": { "const": "tail" },
    "ok": { "type": "boolean" },
    "message": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["iterations", "interval_seconds", "runs"],
      "properties": {
        "iterations": { "type": "integer" },
        "interval_seconds": { "type": "integer" },
        "runs": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
