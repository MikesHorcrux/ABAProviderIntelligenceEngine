{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://provider-intel.local/schemas/cli/v1/control.json",
  "title": "Provider Intel control output",
  "type": "object",
  "required": ["schema_version", "command", "ok", "data"],
  "properties": {
    "schema_version": { "const": "provider_intel.cli.v1" },
    "command": { "const": "control" },
    "ok": { "type": "boolean" },
    "message": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["run_id", "status", "current_seed_domain", "recent_interventions", "domains", "agent_controls"],
      "properties": {
        "run_id": { "type": "string" },
        "status": { "type": "string" },
        "current_seed_domain": { "type": "string" },
        "recent_interventions": { "type": "array", "items": { "type": "object" } },
        "domains": { "type": "object" },
        "agent_controls": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
